{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx shadcn@latest:*)",
      "Bash(rm:*)",
      "Bash(npm cache:*)",
      "Bash(npx next:*)",
      "Bash(npm run:*)",
      "Bash(timeout 15 npx:*)",
      "Bash(npx:*)",
      "Bash(netstat -ano)",
      "Bash(xargs -r taskkill /F /PID)",
      "Bash(taskkill:*)",
      "Bash(cmd:*)",
      "mcp___magicuidesign_mcp__getBackgrounds",
      "mcp___magicuidesign_mcp__getTextAnimations",
      "mcp___magicuidesign_mcp__getSpecialEffects",
      "Bash(npm audit *)",
      "Read(//private/tmp/**)",
      "Bash(curl -s https://cdn.simpleicons.org/openai -o openai.svg)",
      "Bash(curl -s https://cdn.simpleicons.org/googlegemini -o gemini.svg)",
      "Bash(curl -s https://cdn.simpleicons.org/claude -o claude.svg)",
      "Bash(curl -s https://cdn.simpleicons.org/perplexity -o perplexity.svg)",
      "Bash(curl -sL -w \"HTTP %{http_code}\\\\n\" https://cdn.simpleicons.org/openai -o /tmp/openai.svg)",
      "Bash(curl -sL -w \"HTTP %{http_code}\\\\n\" https://unpkg.com/simple-icons@latest/icons/openai.svg -o /tmp/openai2.svg)",
      "Read(//tmp/**)",
      "Bash(git add *)",
      "Bash(git commit -m 'docs: spec do bloco '\\\\''Pergunte ao seu LLM'\\\\'' na seção FAQ *)",
      "Bash(grep -A4 -E \"app/contato/page.tsx$|app/suporte/page.tsx$|layout/footer.tsx$\")",
      "Bash(node *)"
    ]
  },
  "enabledMcpjsonServers": [
    "shadcn",
    "@magicuidesign/mcp"
  ],
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true
  }
}
