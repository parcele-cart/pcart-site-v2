{
  "mcpServers": {
    "shadcn": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "shadcn@latest",
        "mcp"
      ]
    },
    "@magicuidesign/mcp": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@magicuidesign/mcp@latest"
      ]
    }
  }
}